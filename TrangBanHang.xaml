<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRPayApp.TrangBanHang" Title="Thanh toán">
    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="15" RowSpacing="10">

        <SearchBar x:Name="txtTim" Placeholder="Tìm sản phẩm..." TextChanged="timKiem" />

        <CollectionView Grid.Row="1" x:Name="listSp">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, 80, 80" Padding="5">
                        <Label Text="{Binding ten}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding gia}" VerticalOptions="Center"/>
                        <Entry Grid.Column="2" Placeholder="SL" Keyboard="Numeric" Text="{Binding soLuong}" TextChanged="tinhTien"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="2" x:Name="lblTong" Text="Tổng: 0 VND" FontSize="20" FontAttributes="Bold" HorizontalOptions="End"/>

        <VerticalStackLayout Grid.Row="3" Spacing="5">
            <Button Text="TẠO QR &amp; THANH TOÁN" Clicked="thanhToan" BackgroundColor="Blue" TextColor="White"/>
            <Image x:Name="imgQR" HeightRequest="200" IsVisible="False"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>