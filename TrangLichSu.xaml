<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRPayApp.TrangLichSu" Title="Lich Su">
    <ListView x:Name="listHd" ItemSelected="xemLaiQR">
        <ListView.ItemTemplate>
            <DataTemplate>
                <TextCell Text="{Binding ngay}" Detail="{Binding tong, StringFormat='Tong: {0:N0} VND'}"/>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentPage>