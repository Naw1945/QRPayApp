<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRPayApp.TrangLichSu" 
             Title="Lịch sử">

    <ListView x:Name="listHd" ItemSelected="xemLaiQR" HasUnevenRows="True">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <VerticalStackLayout Padding="15" Spacing="5">

                        <Label Text="{Binding ngay}" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="DeepSkyBlue" />

                        <Label Text="{Binding tong, StringFormat='Tổng: {0:N0} VND'}" 
                               FontSize="16" 
                               TextColor="Gray" />

                    </VerticalStackLayout>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>

</ContentPage>