<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRPayApp.TrangCaiDat" Title="Cài đặt ">
    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Thiết lập tài khoản nhận tiền " FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Label Text="Chọn ngân hàng :" FontAttributes="Bold"/>
        <Picker x:Name="cboNganHang" ItemDisplayBinding="{Binding ten}" SelectedIndexChanged="chonNganHang"/>

        
        <Entry x:Name="txtBin" IsVisible="False" />

        <Label Text="Số tài khoản :" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Entry x:Name="txtSoTaiKhoan" Keyboard="Numeric" />

        <Button Text="LƯU CÀI ĐẶT" Clicked="luuThongTin" BackgroundColor="Blue" TextColor="White" Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>