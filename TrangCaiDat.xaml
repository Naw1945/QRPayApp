<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRPayApp.TrangCaiDat" Title="Cai Dat">
    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Thiet lap tai khoan nhan tien" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Label Text="Chon Ngan Hang:" FontAttributes="Bold"/>
        <Picker x:Name="cboNganHang" ItemDisplayBinding="{Binding ten}" SelectedIndexChanged="chonNganHang"/>

        <Label Text="Ma BIN:" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Entry x:Name="txtBin" IsReadOnly="True" BackgroundColor="LightGray" />

        <Label Text="So Tai Khoan:" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Entry x:Name="txtSoTaiKhoan" Keyboard="Numeric" />

        <Button Text="LUU CAI DAT" Clicked="luuThongTin" BackgroundColor="Blue" TextColor="White" Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>